{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Syne",
  "version": "0.1.0",
  "identifier": "com.syne.desktop",
  "build": {
    "beforeDevCommand": "npm run build:sidecar && npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "externalBin": ["binaries/syne-ui-api"]
  },
  "app": {
    "windows": [
      {
        "title": "Syne",
        "width": 1520,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true
      }
    ]
  }
}
